# ─────────────────────────────────────────────────────────────────────────────
# NekoFetch — environment configuration
# Copy to `.env` and fill in. Secrets & connection strings only.
# Feature behaviour lives in config.yaml and the in-Telegram settings panel.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram API (https://my.telegram.org) ──
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Admin / management bot token (from @BotFather)
ADMIN_BOT_TOKEN=

# Comma-separated Telegram user IDs with full admin access (whitelist seed)
ADMIN_IDS=

# ── Security ──
# Used to encrypt stored distribution-bot tokens (Fernet). Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# ── PostgreSQL ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=nekofetch
POSTGRES_PASSWORD=change-me
POSTGRES_DB=nekofetch

# ── MongoDB ──
MONGO_URI=mongodb://mongo:27017
MONGO_DB=nekofetch

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Storage ──
STORAGE_PATH=/data/storage
SESSION_PATH=/data/sessions

# ── Logging ──
LOG_LEVEL=INFO
LOG_JSON=false
